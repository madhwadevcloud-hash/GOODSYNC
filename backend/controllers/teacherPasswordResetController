const crypto = require('crypto');
const bcrypt = require('bcryptjs');
const UserGenerator = require('../utils/userGenerator');
const { sendTeacherPasswordResetEmail } = require('../utils/emailService');
const { validatePasswordStrength } = require('../utils/passwordValidator');

const ROLE = 'teacher';
const TOKEN_TTL_MINUTES = 20; // within the required 15-30 minute window

// Generic message used for both "email exists" and "email doesn't exist" cases,
// so the API never reveals whether an account exists.
const GENERIC_RESPONSE_MESSAGE =
  'If an account with this email exists, a password reset link has been sent.';

function hashToken(rawToken) {
  return crypto.createHash('sha256').update(rawToken).digest('hex');
}

function buildResetUrl(rawToken, schoolCode) {
  const base = process.env.FRONTEND_URL || 'http://localhost:5173';
  const trimmedBase = base.endsWith('/') ? base.slice(0, -1) : base;
  return `${trimmedBase}/teacher/reset-password?token=${rawToken}&schoolCode=${encodeURIComponent(schoolCode)}`;
}

/**
 * POST /api/auth/teacher/forgot-password
 * Body: { email }
 *
 * Always responds with a generic message regardless of whether the email
 * belongs to a teacher account, to avoid user enumeration.
 */
exports.forgotPassword = async (req, res) => {
  try {
    const { email } = req.body;

    if (!email || typeof email !== 'string' || !email.trim()) {
      return res.status(400).json({ success: false, message: 'Email is required.' });
    }

    const trimmedEmail = email.trim();

    // Look up the account, scoped strictly to teacher accounts.
    const match = await UserGenerator.findUserByEmailAcrossSchools(trimmedEmail, ROLE);

    if (match && match.user) {
      const { schoolCode, user } = match;

      try {
        const rawToken = crypto.randomBytes(32).toString('hex');
        const hashedToken = hashToken(rawToken);
        const expiresAt = new Date(Date.now() + TOKEN_TTL_MINUTES * 60 * 1000);

        await UserGenerator.setPasswordResetToken(schoolCode, ROLE, user._id, hashedToken, expiresAt);

        const resetUrl = buildResetUrl(rawToken, schoolCode);
        const teacherName =
          user.name?.displayName ||
          [user.name?.firstName, user.name?.lastName].filter(Boolean).join(' ') ||
          user.name ||
          'there';

        await sendTeacherPasswordResetEmail({
          to: user.email,
          teacherName,
          resetUrl,
          expiresInMinutes: TOKEN_TTL_MINUTES
        });
      } catch (innerError) {
        // Do not leak internal errors to the client - log and still return the generic response.
        console.error('[TEACHER FORGOT PASSWORD] Error generating/sending reset token:', innerError);
      }
    }

    return res.status(200).json({ success: true, message: GENERIC_RESPONSE_MESSAGE });
  } catch (error) {
    console.error('[TEACHER FORGOT PASSWORD ERROR]', error);
    // Still avoid leaking whether the email exists; return a generic success-shaped message.
    return res.status(200).json({ success: true, message: GENERIC_RESPONSE_MESSAGE });
  }
};

/**
 * POST /api/auth/teacher/reset-password
 * Body: { token, schoolCode, newPassword, confirmPassword }
 */
exports.resetPassword = async (req, res) => {
  try {
    const { token, schoolCode, newPassword, confirmPassword } = req.body;

    if (!token || !schoolCode || !newPassword || !confirmPassword) {
      return res.status(400).json({
        success: false,
        message: 'Token, school code, new password, and confirmation are required.'
      });
    }

    if (newPassword !== confirmPassword) {
      return res.status(400).json({ success: false, message: 'Passwords do not match.' });
    }

    const strength = validatePasswordStrength(newPassword);
    if (!strength.valid) {
      return res.status(400).json({ success: false, message: strength.message });
    }

    const hashedToken = hashToken(token);
    const user = await UserGenerator.findByPasswordResetToken(schoolCode, ROLE, hashedToken);

    if (!user) {
      return res.status(400).json({
        success: false,
        message: 'This password reset link is invalid or has expired. Please request a new one.'
      });
    }

    const hashedPassword = await bcrypt.hash(newPassword, 10);
    await UserGenerator.completePasswordReset(schoolCode, ROLE, user._id, hashedPassword);

    return res.status(200).json({
      success: true,
      message: 'Your password has been reset successfully. You can now log in with your new password.'
    });
  } catch (error) {
    console.error('[TEACHER RESET PASSWORD ERROR]', error);
    return res.status(500).json({
      success: false,
      message: 'Something went wrong while resetting your password. Please try again.'
    });
  }
};
